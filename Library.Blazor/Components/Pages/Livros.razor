@page "/livros"
@rendermode InteractiveServer
@using Library.Blazor.Application.DTOs.Livros
@using Library.Blazor.Domain.Entities
@using Library.Blazor.Domain.Services
@using Library.Blazor.Infrastructure.Services
@inject LivroService LivroService
@inject OpenLibraryService OpenLibraryService

<div class="container py-5 @(modoEscuro ? "dark-mode" : "")">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title">Minha Biblioteca</h1>
            <p class="page-subtitle">Organize sua coleção pessoal</p>
        </div>

        <button class="btn btn-outline-secondary" @onclick="AlternarTema">
            @(modoEscuro ? "☀️" : "🌙")
        </button>

        <button class="btn btn-dark px-4 add-book-btn" @onclick="MostrarFormulario">
            + Novo Livro
        </button>
    </div>

    @if (mostrarFormulario)
    {
        <div class="modal-backdrop-custom"
             @onclick="CancelarFormulario">

            <div class="modal-custom"
                 @onclick:stopPropagation="true">

                <div class="modal-header-custom">
                    <h4 class="mb-0">Adicionar Livro</h4>

                    <button class="btn-close"
                            @onclick="CancelarFormulario">
                    </button>
                </div>

                <div class="modal-body-custom">

                    <EditForm Model="novoLivro"
                              OnValidSubmit="SalvarLivro">

                        <div class="row g-4 align-items-start">

                            <div class="col-md-4">

                                @if (!string.IsNullOrWhiteSpace(capaPreview))
                                {
                                    <img src="@capaPreview"
                                         class="img-fluid rounded shadow-sm w-100"
                                         alt="Capa do Livro" />
                                }
                                else
                                {
                                    <div class="cover-placeholder">
                                        Sem Capa
                                    </div>
                                }

                            </div>

                            <div class="col-md-8">

                                <div class="mb-3">
                                    <label class="form-label">Título</label>

                                    <div class="d-flex gap-2">
                                        <InputText class="form-control"
                                                   @bind-Value="novoLivro.Titulo" />

                                        <button type="button"
                                                class="btn btn-outline-primary"
                                                @onclick="BuscarMetadata">
                                            Buscar
                                        </button>
                                    </div>

                                    @if (resultadosBusca.Any())
                                    {
                                        <div class="search-results mt-2">

                                            @foreach (var item in resultadosBusca)
                                            {
                                                <button type="button"
                                                        class="result-card"
                                                        @onclick="() => SelecionarResultado(item)">

                                                    <strong>@item.Titulo</strong><br />
                                                    <small>@item.Autor (@item.Ano)</small>

                                                </button>
                                            }

                                        </div>
                                    }
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Autor</label>
                                    <InputText class="form-control"
                                               @bind-Value="novoLivro.Autor" />
                                </div>

                                <div class="row g-3">

                                    <div class="col-md-6">
                                        <label class="form-label">Publicação</label>
                                        <InputDate class="form-control"
                                                   @bind-Value="novoLivro.DataPublicacao" />
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Idioma</label>
                                        <InputText class="form-control"
                                                   @bind-Value="novoLivro.Idioma" />
                                    </div>

                                </div>

                                <div class="mt-3 mb-3">
                                    <label class="form-label">Descrição</label>
                                    <InputTextArea class="form-control"
                                                   rows="5"
                                                   @bind-Value="novoLivro.Descricao" />
                                </div>

                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button"
                                            class="btn btn-outline-secondary"
                                            @onclick="CancelarFormulario">
                                        Cancelar
                                    </button>

                                    <button type="submit"
                                            class="btn btn-success">
                                        Salvar
                                    </button>
                                </div>

                            </div>

                        </div>

                    </EditForm>

                </div>

            </div>

        </div>
    }

    @if (livros.Count == 0)
    {
        <div class="text-center border rounded p-5 bg-light">
            <h4>Sua biblioteca está vazia</h4>
            <p class="text-muted">Adicione seu primeiro livro para começar.</p>
        </div>
    } else
    {
        <div class="row g-4">
            @foreach (var livro in livros)
            {
                <div class="col-md-6 col-lg-4">

                    <div class="card shadow-sm book-card h-100">
                        <div class="card-body d-flex flex-column">

                            <h5 class="fw-bold mb-1">
                                @livro.Titulo
                            </h5>
                            <p class="text-muted mb-3">@livro.Autor</p>

                            <div class="mt-auto d-flex justify-content-between align-items-center">

                                <span class="badge bg-secondary">@livro.StatusLeitura</span>

                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoverLivro(livro.Id)">Remover</button>

                            </div>

                            <div class="mt-3 small fw-semibold">
                                <button class="favorite-btn @(livro.Favorito ? "active" : "")"
                                        @onclick="() => AlternarFavorito(livro.Id)"
                                        title="@(livro.Favorito ? "Remover dos favoritos" : "Adicionar aos favoritos")"
                                        style="color:@(livro.Favorito ? "#FFC107" : "#6C757D")">

                                    @(livro.Favorito ? "⭐" : "☆")

                                </button>
                            </div>

                        </div>

                    </div>
                </div>

            }

        </div>
    }


</div>

@code {
    private bool modoEscuro = true;

    private void AlternarTema()
    {
        modoEscuro = !modoEscuro;
    }

    private List<Livro> livros = new();

    private List<LivroBuscaDto> resultadosBusca = new();

    private string capaPreview = "";

    private bool mostrarFormulario = false;

    private CriarLivroDto novoLivro = new();

    protected override async Task OnInitializedAsync()
    {
        livros = await LivroService.ObterTodosAsync();
    }

    private void MostrarFormulario()
    {
        mostrarFormulario = true;
    }

    private void CancelarFormulario()
    {
        mostrarFormulario = false;
        novoLivro = new CriarLivroDto();
        capaPreview = "";
    }

    private async Task SalvarLivro()
    {
        await LivroService.AdicionarAsync(novoLivro);

        livros = await LivroService.ObterTodosAsync();

        novoLivro = new CriarLivroDto();

        mostrarFormulario = false;

        capaPreview = "";
    }

    private async Task RemoverLivro(int id)
    {
        await LivroService.RemoverAsync(id);
        livros = await LivroService.ObterTodosAsync();
    }

    private async Task AlternarFavorito(int id)
    {
        await LivroService.AlternarFavoritoAsync(id);
        livros = await LivroService.ObterTodosAsync();
    }

    private async Task BuscarMetadata()
    {
        if (string.IsNullOrWhiteSpace(novoLivro.Titulo))
            return;

        resultadosBusca =
            await OpenLibraryService.BuscarMultiplosAsync(novoLivro.Titulo);
    }

    private async Task SelecionarResultado(LivroBuscaDto item)
    {
        var dados =
            await OpenLibraryService.BuscarDetalhesAsync(item.Key);

        if (dados == null)
            return;

        novoLivro.Titulo = item.Titulo;
        novoLivro.Autor = item.Autor;

        novoLivro.Descricao = dados.Descricao;
        novoLivro.Idioma = dados.Idioma;
        novoLivro.DataPublicacao =
            dados.DataPublicacao;

        capaPreview = item.CapaUrl;

        resultadosBusca.Clear();
    }

