@page "/livros/ler/{Id:int}"
@rendermode InteractiveServer

@implements IAsyncDisposable

@using Library.Blazor.Domain.Entities
@using Library.Blazor.Domain.Services
@inject LivroService LivroService
@inject NavigationManager Nav
@inject IJSRuntime JS


@if (livro != null)
{
    <div class="reader-shell">

        <header class="reader-header @(mostrarHeader ? "show-header" : "hide-header")">

            <div class="reader-left">

                <button type="button"
                        class="back-btn"
                        @onclick="VoltarBiblioteca">
                    ← Voltar
                </button>

                <div>
                    <div class="reader-title">
                        @livro.Titulo
                    </div>

                    <div class="reader-author">
                        @livro.Autor
                    </div>
                </div>

            </div>

            <div class="reader-actions">
                <button class="reader-btn" @onclick="AtivarFullscreen">⛶ Tela Cheia</button>

                <button class="reader-btn" @onclick='PaginaAnterior'>◀</button>
                <button class="reader-btn" @onclick='ProximaPagina'>▶</button>
                <button class="reader-btn" @onclick='ZoomOut'>−</button>
                <button class="reader-btn" @onclick='ZoomIn'>＋</button>

                <a href="@livro.ArquivoUrl" download class="reader-btn">⬇ Baixar</a>
            </div>

        </header>

        <div class="reader-content">
            <canvas id="pdf-canvas" class="reader-canvas"></canvas>
        </div>

    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Livro? livro;

    private bool mostrarHeader = true;

    private DotNetObjectReference<LerLivro>? objRef;

    private CancellationTokenSource? headerCts;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        livro = await LivroService.ObterParaEdicaoAsync(Id);

        await LivroService.RegistrarLeituraAsync(Id);
    }

    private void VoltarBiblioteca()
    {
        Nav.NavigateTo("/livros");
    }

    private async Task AtivarFullscreen()
    {
        await JS.InvokeVoidAsync("readerFullscreen");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync(
                "readerMouseWatcher",
                objRef);

            if (livro?.ArquivoUrl != null)
            {
                await JS.InvokeVoidAsync("initPdfViewer", "pdf-canvas", livro.ArquivoUrl);
            }
        }
    }

    [JSInvokable]
    public void MostrarHeaderTemporariamente()
    {
        if (_disposed) return;

        if (!mostrarHeader)
        {
            mostrarHeader = true;
            StateHasChanged();
        }

        headerCts?.Cancel();
        headerCts = new CancellationTokenSource();
        var token = headerCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(3000, token);
                if (_disposed) return;
                await InvokeAsync(() =>
                {
                    if (_disposed) return;
                    mostrarHeader = false;
                    StateHasChanged();
                });
            }
            catch (TaskCanceledException) { }
            catch (ObjectDisposedException) { }
        });
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        headerCts?.Cancel();
        headerCts?.Dispose();

        try { await JS.InvokeVoidAsync("readerDestroy"); } catch { }

        objRef?.Dispose();
    }

    private async Task PaginaAnterior()
    {
        await JS.InvokeVoidAsync("pdfViewerPrev");
    }

    private async Task ProximaPagina()
    {
        await JS.InvokeVoidAsync("pdfViewerNext");
    }

    private async Task ZoomOut()
    {
        await JS.InvokeVoidAsync("pdfViewerZoomOut");
    }

    private async Task ZoomIn()
    {
        await JS.InvokeVoidAsync("pdfViewerZoomIn");
    }

}